{
  "name": "@travisliu/open-dynamic-workflow",
  "version": "0.4.0",
  "description": "Local-first workflow CLI for orchestrating coding-agent CLIs.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "Open Dynamic Workflow contributors",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./_comment": "Expose ./cli subpath for backward compatibility with @prmflow/openflow",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "default": "./dist/cli/index.js"
    }
  },
  "bin": {
    "open-dynamic-workflow": "dist/bin/open-dynamic-workflow.js",
    "odw": "dist/bin/open-dynamic-workflow.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/travisliu/open-dynamic-workflow.git"
  },
  "bugs": {
    "url": "https://github.com/travisliu/open-dynamic-workflow/issues"
  },
  "homepage": "https://github.com/travisliu/open-dynamic-workflow#readme",
  "keywords": [
    "workflow",
    "cli",
    "agent",
    "orchestration",
    "local-first"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "postbuild": "node scripts/fix-bin-permissions.mjs",
    "dev": "tsx src/bin/open-dynamic-workflow.ts",
    "start": "node dist/bin/open-dynamic-workflow.js",
    "typecheck": "npm run check",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --reporter=dot --no-color",
    "prepack": "npm run clean && npm run build",
    "pack:local": "npm pack",
    "publish:dry-run": "npm publish --dry-run",
    "release:check": "npm run build && npm run typecheck && npm run lint && npm test && npm pack --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "20",
    "eslint": "^10.5.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "commander": "^15.0.0",
    "tinyglobby": "^0.2.17",
    "typescript": "^5.8.0",
    "yaml": "^2.9.0"
  }
}
